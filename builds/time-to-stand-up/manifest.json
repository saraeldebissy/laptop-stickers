{
  "manifest_version": 3,
  "name": "Time to Stand Up",
  "version": "1.0.0",
  "description": "Apple Watch–style daily stand-up reminder at 1:00 PM",
  "permissions": ["alarms", "windows", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
